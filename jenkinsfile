pipeline {
  agent any

  environment {
    FRONTEND_IMAGE = 'frontend'
    BACKEND_IMAGE  = 'backend'
    BUILD_TAG      = "${env.BUILD_NUMBER}"
  }

  stages {

    stage('Checkout Frontend') {
      steps {
        dir('frontend') {
          git branch: 'main',
              url: 'https://github.com/psrividhya01/Auth-Frontend.git',
              credentialsId: 'github-credentials'
        }
      }
    }

    stage('Checkout Backend') {
      steps {
        dir('backend') {
          git branch: 'main',
              url: 'https://github.com/psrividhya01/Auth-backend.git',
              credentialsId: 'github-credentials'
        }
      }
    }

    stage('Build & Test') {
      parallel {

        stage('Frontend') {
          steps {
            dir('frontend') {
              bat 'npm install'
              bat 'npx ng build --configuration=production'
            }
          }
        }

        stage('Backend') {
          steps {
            dir('backend') {
              bat 'dotnet restore'
              bat 'dotnet test'
              bat 'dotnet publish -c Release -o ./publish'
            }
          }
        }

      }
    }

    stage('Docker Build') {
      parallel {

        stage('Frontend Docker') {
          steps {
            dir('frontend') {
              bat "docker build -t ${FRONTEND_IMAGE}:${BUILD_TAG} ."
              bat "docker tag ${FRONTEND_IMAGE}:${BUILD_TAG} ${FRONTEND_IMAGE}:latest"
            }
          }
        }

        stage('Backend Docker') {
          steps {
            dir('backend') {
              bat "docker build -t ${BACKEND_IMAGE}:${BUILD_TAG} ."
              bat "docker tag ${BACKEND_IMAGE}:${BUILD_TAG} ${BACKEND_IMAGE}:latest"
            }
          }
        }

      }
    }

    stage('Run Containers') {
      steps {
        bat "docker stop frontend-container || exit 0"
        bat "docker rm   frontend-container || exit 0"
        bat "docker stop backend-container  || exit 0"
        bat "docker rm   backend-container  || exit 0"
        bat "docker run -d --name frontend-container -p 4200:80 ${FRONTEND_IMAGE}:latest"
        bat "docker run -d --name backend-container  -p 5000:80 ${BACKEND_IMAGE}:latest"
      }
    }

    stage('Health Check') {
      steps {
        sleep(time: 10, unit: 'SECONDS')
        bat 'curl -f http://localhost:5000/health || exit 0'
      }
    }

  }

  post {
    success {
      echo 'Build successful and containers are running!'
    }
    failure {
      echo 'Pipeline failed — check the logs above.'
    }
  }
}
